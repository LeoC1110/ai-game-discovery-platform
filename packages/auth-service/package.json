{
  "name": "@services/auth",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch . --ext js,mjs,cjs,json,env server.js",
    "dev:mock": "cross-env AI_MOCK_MODE=true nodemon --watch . --ext js,mjs,cjs,json,env server.js",
    "dev:real": "cross-env AI_MOCK_MODE=false nodemon --watch . --ext js,mjs,cjs,json,env server.js",
    "start": "node server.js",
    "backfill:title-normalized": "node scripts/backfillTitleNormalized.js",
    "backfill:title-normalized:apply": "node scripts/backfillTitleNormalized.js --apply",
    "backfill:community-ratings-to-game-id": "node scripts/backfillCommunityRatingsToGameId.js",
    "backfill:community-ratings-to-game-id:apply": "node scripts/backfillCommunityRatingsToGameId.js --apply",
    "backfill:hubspot": "node scripts/backfillHubSpotContacts.js --dry-run",
    "backfill:hubspot:apply": "node scripts/backfillHubSpotContacts.js --apply",
    "rag:init": "node scripts/initializeGameEmbeddings.js --dry-run",
    "rag:init:apply": "node scripts/initializeGameEmbeddings.js --apply",
    "rag:init:force": "node scripts/initializeGameEmbeddings.js --apply --force",
    "test": "cross-env NODE_ENV=test node --test ai/__tests__/mockMode.test.js ai/__tests__/pipeline.test.js ai/__tests__/routerAgent.test.js ai/__tests__/answerAgent.test.js ai/__tests__/validatorAgent.test.js ai/__tests__/aiPipeline.test.js __tests__/passwordReset.test.js"
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@as-integrations/express4": "^1.1.2",
    "@langchain/core": "^1.1.46",
    "@langchain/google-genai": "^2.1.30",
    "@shared/jwt": "file:../../shared/jwt",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.0",
    "graphql": "^16.11.0",
    "langchain": "^1.4.0",
    "mongoose": "^8.19.1",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.10"
  }
}
