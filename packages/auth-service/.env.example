# =============================================
# Auth Service — Environment Variables Example
# Copy this file to .env and fill in real values
# NEVER commit your real .env file to Git
# =============================================

# MongoDB
MONGODB_URI=your_mongodb_uri_here

# JWT
JWT_SECRET=your_jwt_secret_here

# Server
PORT=4001

# Google Gemini (AI Game Agent)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# AI configuration (optional — safe defaults are used if omitted)
AI_MODEL=gemini-2.0-flash
AI_MAX_HISTORY_MESSAGES=10
AI_MAX_PLATFORM_POSTS=20
AI_TIMEOUT_MS=30000
AI_WARMUP_ON_START=false

# Tavily Web Search (optional — enables search_web tool for the AI agent)
# Free tier: 1 000 searches/month. Get your key at: https://app.tavily.com
# Leave unset to disable web search entirely (agent uses only platform data).
# Built-in rate limits: 30 searches/day global, 3 searches/hour per user.
TAVILY_API_KEY=
